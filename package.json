{
  "name": "clawdia7",
  "version": "7.0.0",
  "description": "AI desktop workspace — UI shell (Clawdia 7.0).",
  "author": "Daniel Parker",
  "license": "MIT",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev": "tsc -p tsconfig.main.json",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5174 dist/main/main.js dist/main/preload.js && nodemon --watch dist/main --watch dist/shared --exec \"cross-env NODE_ENV=development electron --no-sandbox .\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "cross-env NODE_ENV=production electron --no-sandbox .",
    "package": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.33.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "39.5.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.3"
  }
}
